{
  "name": "herdr-agent-board",
  "version": "0.1.0",
  "description": "Local, provenance-aware Herdr agent board",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "bun run format:check && bun run lint && bun run typecheck && bun test",
    "format": "prettier --write src tests scripts docs README.md dependencies.md package.json tsconfig.json .prettierrc.json",
    "format:check": "prettier --check src tests scripts docs README.md dependencies.md package.json tsconfig.json .prettierrc.json",
    "lint": "oxlint src tests",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "start": "bun run src/main.tsx",
    "start:popup": "bun run src/main.tsx --mode popup",
    "start:tab": "bun run src/main.tsx --mode tab",
    "smoke": "bun run scripts/smoke.ts",
    "privacy:smoke": "bun run scripts/privacy-smoke.ts",
    "plugin:smoke": "bun run scripts/plugin-smoke.ts",
    "benchmark": "bun run scripts/benchmark.ts",
    "build": "bun build src/main.tsx --outdir dist --target bun --external '@opentui/core-*'",
    "docs:smoke": "bun run scripts/docs-smoke.ts"
  },
  "dependencies": {
    "@opentui/core": "0.4.5",
    "@opentui/react": "0.4.5",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "oxlint": "1.74.0",
    "prettier": "3.9.5",
    "typescript": "7.0.2"
  }
}
